{
  "name": "lichborne",
  "version": "0.1.10",
  "description": "DragonRealms game client with Lich support and AI features",
  "main": "dist/main/main.js",
  "scripts": {
    "dev:renderer": "vite",
    "build": "npm run build:main && npm run build:renderer",
    "build:main": "node build-main.mjs",
    "build:renderer": "vite build",
    "start": "npm run build:main && npm run build:renderer && electron .",
    "dist": "npm run build && electron-builder --win nsis"
  },
  "build": {
    "appId": "com.lichborne.app",
    "productName": "Lichborne",
    "files": ["dist/**/*"],
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      "artifactName": "${productName}-${version}-setup.exe"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "extraResources": [
      { "from": "build/app-update.yml", "to": "app-update.yml" }
    ],
    "publish": {
      "provider": "github",
      "owner": "SekmehtDR",
      "repo": "Lichborne",
      "releaseType": "draft"
    },
    "releaseInfo": {}
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "concurrently": "^8.0.0",
    "electron": "^31.0.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.28.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0"
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  }
}
