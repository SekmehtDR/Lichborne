{
  "name": "lichborne",
  "version": "0.15.2",
  "description": "DragonRealms game client with a primary Lich integration focus.",
  "main": "dist/main/main.js",
  "scripts": {
    "dev:renderer": "vite",
    "build": "npm run build:main && npm run build:renderer",
    "build:main": "node build-main.mjs",
    "build:renderer": "vite build",
    "start": "npm run build:main && npm run build:renderer && electron .",
    "dist": "npm run build && electron-builder --win nsis"
  },
  "build": {
    "appId": "com.lichborne.app",
    "productName": "Lichborne",
    "files": [
      "dist/**/*"
    ],
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "${productName}-${version}-setup.exe"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "include": "build/installer.nsh"
    },
    "extraResources": [
      {
        "from": "build/app-update.yml",
        "to": "app-update.yml"
      }
    ],
    "publish": {
      "provider": "github",
      "owner": "SekmehtDR",
      "repo": "Lichborne",
      "releaseType": "draft"
    },
    "releaseInfo": {}
  },
  "devDependencies": {
    "@electron/rebuild": "^4.1.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.0.0",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.7.0",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "electron-updater": "^6.8.9",
    "esbuild": "^0.28.1",
    "highlight.js": "^11.11.1",
    "js-yaml": "^4.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-virtuoso": "^4.18.10",
    "typescript": "^5.9.3",
    "vite": "^5.4.21"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1"
  }
}
