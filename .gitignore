# Dependencies
node_modules/

# Build output
dist/
release/
*.tsbuildinfo

# Runtime / user data
profiles/
Exports/
Logs/

# SceneParser raw-XML capture corpus — contains other players' chatter; never commit
corpus/

# Local harnesses (tmp-scene-harness = the SceneParser capturer regression
# suite, tmp-scroll-repro = the B171/B172 scroll simulation, tmp-cmd-harness =
# command resolution, tmp-rules-harness = global rules/Transfer/reconnect).
# Kept OUT of the repo on purpose: the scene harness embeds verbatim corpus
# lines with real player names (Sekmeht, 2026-06-12 — same privacy stance as
# corpus/). They live machine-local; each README/recipe documents rebuilds.
tmp-*/

# Per-version test plans (Sekmeht, 2026-07-10): machine-local working
# checklists, like the harnesses they feed. Part of the "update my
# documentation" set but not committed.
testplans/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment / secrets
.env
.env.local
.env.*.local

# Editor & tool leftovers
*.bak
*.orig
*.tmp
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db

# Claude Code local config
.claude/
